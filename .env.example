# ─────────────────────────────────────────────────────────────────────────────
# AlcoaBase Environment Configuration
# Copy this file to .env and fill in the values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=alcoabase
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=alcoabase
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=alcoabase
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_BUCKET=alcoabase
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─────────────────────────────────────────────────────────────────────────────
# OpenSearch (vectors + search)
# ─────────────────────────────────────────────────────────────────────────────
OPENSEARCH_PORT=9200

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Celery broker)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# vLLM / Model Configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# AlcoaBase ships with two model profiles:
#
#   SMALL  – fast iteration on a single consumer GPU (24 GB VRAM).
#            Active by default below.
#   LARGE  – production quality on high-end hardware (≥80 GB VRAM).
#            Commented out; uncomment to switch.
#
# Swapping profiles only requires changing these env vars and downloading
# the new weights — no code or OpenSearch index changes needed (all models
# in a given role share the same embedding dimension / API contract).
# ─────────────────────────────────────────────────────────────────────────────

# Path to pre-downloaded model weights on the host (mounted as /models/ in container)
MODEL_WEIGHTS_PATH=./models

# ── Chat / Generation LLM ──────────────────────────────────────────────────
# SMALL: Qwen3.6 35B MoE — only 3B active params, fits on 24 GB GPU (~8 GB)
MODEL_CHAT_NAME=Qwen/Qwen3.6-35B-A3B
MODEL_CHAT_PATH=/models/qwen3.6-35b-a3b
MODEL_CHAT_MAX_GPU_MEMORY_GB=24
# LARGE (uncomment to upgrade):
# MODEL_CHAT_NAME=meta-llama/Llama-3.3-70B-Instruct
# MODEL_CHAT_PATH=/models/llama-3.3-70b-instruct
# MODEL_CHAT_MAX_GPU_MEMORY_GB=60

# ── Multilingual Embedding Model ───────────────────────────────────────────
# SMALL: Qwen3-Embedding 0.6B — 1024-dim output, same as e5-large-instruct
MODEL_EMBEDDING_NAME=Qwen/Qwen3-Embedding-0.6B
MODEL_EMBEDDING_PATH=/models/qwen3-embedding-0.6b
MODEL_EMBEDDING_DIMENSION=1024
# LARGE (uncomment to upgrade):
# MODEL_EMBEDDING_NAME=Qwen/Qwen3-Embedding-8B
# MODEL_EMBEDDING_PATH=/models/qwen3-embedding-8b
# MODEL_EMBEDDING_DIMENSION=1024

# ── Vision / OCR Model (loaded on-demand for scanned PDFs) ─────────────────
# SMALL: Gemma 4 E4B — effective 4B vision+text, native OCR, fits on 24 GB
MODEL_OCR_NAME=google/gemma-4-E4B-it
MODEL_OCR_PATH=/models/gemma-4-e4b-it
# LARGE (uncomment to upgrade):
# MODEL_OCR_NAME=Qwen/Qwen2.5-VL-72B-Instruct
# MODEL_OCR_PATH=/models/qwen2.5-vl-72b-instruct

# GPU Configuration
GPU_DEVICE_ID=0
VLLM_PORT=8000

# Model Manager Mode: "gpu" (production), "cpu" (CPU inference), "mock" (dev/test)
MODEL_MANAGER_MODE=mock

# ─────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI)
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
SECRET_KEY=changeme_secret_key_generate_a_random_value

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (React/Vite)
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# CSV Runner (Playwright validation)
# ─────────────────────────────────────────────────────────────────────────────
CSV_TEST_USER=csv_test_user
CSV_TEST_PASSWORD=changeme_csv_password
