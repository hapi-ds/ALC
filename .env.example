# ─────────────────────────────────────────────────────────────────────────────
# AlcoaBase Environment Configuration
# Copy this file to .env and fill in the values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=alcoabase
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=alcoabase
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=alcoabase
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_BUCKET=alcoabase
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─────────────────────────────────────────────────────────────────────────────
# OpenSearch (vectors + search)
# ─────────────────────────────────────────────────────────────────────────────
OPENSEARCH_INITIAL_ADMIN_PASSWORD=changeme_opensearch
OPENSEARCH_PORT=9200

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Celery broker)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# vLLM / Model Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Path to pre-downloaded model weights on the host (mounted as /models/ in container)
MODEL_WEIGHTS_PATH=./models

# Chat/Generation LLM
MODEL_CHAT_NAME=meta-llama/Llama-3.3-70B-Instruct
MODEL_CHAT_PATH=/models/llama-3.3-70b-instruct
MODEL_CHAT_MAX_GPU_MEMORY_GB=60

# Multilingual Embedding Model
MODEL_EMBEDDING_NAME=intfloat/multilingual-e5-large-instruct
MODEL_EMBEDDING_PATH=/models/multilingual-e5-large-instruct
MODEL_EMBEDDING_DIMENSION=1024

# Vision/OCR Model (loaded on-demand for scanned PDFs)
MODEL_OCR_NAME=Qwen/Qwen2.5-VL-72B-Instruct
MODEL_OCR_PATH=/models/qwen2.5-vl-72b-instruct

# GPU Configuration
GPU_DEVICE_ID=0
VLLM_PORT=8000

# Model Manager Mode: "gpu" (production), "cpu" (CPU inference), "mock" (dev/test)
MODEL_MANAGER_MODE=mock

# ─────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI)
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080
SECRET_KEY=changeme_secret_key_generate_a_random_value

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (React/Vite)
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# CSV Runner (Playwright validation)
# ─────────────────────────────────────────────────────────────────────────────
CSV_TEST_USER=csv_test_user
CSV_TEST_PASSWORD=changeme_csv_password
